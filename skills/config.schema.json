{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "my-subagent config",
  "description": "Model pool and API configuration for my-subagent. Copy to ~/.config/agent-skills/my-subagent/config.json and fill in credentials.",
  "type": "object",
  "properties": {
    "active": {
      "type": "string",
      "description": "Active profile name. Overridden by --profile CLI flag.",
      "default": "default"
    },
    "profiles": {
      "type": "object",
      "description": "Named configuration profiles.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "api_base": {
            "type": "string",
            "description": "LiteLLM or compatible API base URL (e.g. http://host:4000)."
          },
          "api_key": {
            "type": "string",
            "description": "API key for the endpoint."
          },
          "pool": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "description": "Model name." },
                    "api_base": { "type": "string", "description": "Override api_base for this model." },
                    "api_key": { "type": "string", "description": "Override api_key for this model." }
                  },
                  "required": ["name"],
                  "additionalProperties": false
                }
              ]
            },
            "description": "Model names or objects with per-model endpoint overrides. Tasks are distributed evenly across the pool."
          },
          "effort": {
            "type": "string",
            "enum": ["low", "medium", "high", "max"],
            "description": "Default reasoning effort level for dispatched tasks.",
            "default": "max"
          }
        },
        "required": ["pool"],
        "additionalProperties": false
      }
    }
  },
  "required": ["active", "profiles"],
  "additionalProperties": false
}
